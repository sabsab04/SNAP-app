<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/sfondolayoutlogin"
    android:elevation="4dp"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nome e Cognome"
        android:textColor="#555555"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/etNomeCognome"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:background="@android:drawable/editbox_background"
        android:hint="Value"
        android:textColorHint="#777777"
        android:textColor="#000000"
        android:padding="12dp"
        android:inputType="textPersonName" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mansione"
        android:textColor="#555555"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/etMansione"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:background="@android:drawable/editbox_background"
        android:hint="Value"
        android:textColorHint="#777777"
        android:textColor="#000000"
        android:padding="12dp"
        android:inputType="text" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Titolo di studio"
        android:textColor="#555555"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/etTitoloStudio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:background="@android:drawable/editbox_background"
        android:hint="Value"
        android:textColorHint="#777777"
        android:textColor="#000000"
        android:padding="12dp"
        android:inputType="text" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Biografia"
        android:textColor="#555555"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/etBiografia"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_marginBottom="24dp"
        android:background="@android:drawable/editbox_background"
        android:hint="Value"
        android:textColorHint="#777777"
        android:textColor="#000000"
        android:padding="12dp"
        android:gravity="top|start"
        android:inputType="textMultiLine" />

    <Button
        android:id="@+id/btnRegistratiFinal"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:background="@drawable/drawablebottonesignin"
        android:text="Registrati"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        app:backgroundTint="@null" />

</LinearLayout>